# ─── Kubuno Forum — Configuration ─────────────────────────────────────────────
# Copy this file to config.toml and adapt the values.
# Environment variables prefixed with KF__ override this file.
# Example: KF__SERVER__PORT=3117

[server]
host = "127.0.0.1"
port = 3117

[core]
# Kubuno core URL (used to register the module)
url             = "http://127.0.0.1:8080"
# Shared secret — must match server.internal_secret in the core
internal_secret = "change_me"

# ── Database ──────────────────────────────────────────────────────────────────
# Connection parameters are injected by the Kubuno supervisor via
# KUBUNO_DB_HOST / KUBUNO_DB_PORT / KUBUNO_DB_USER / KUBUNO_DB_PASSWORD / KUBUNO_DB_NAME.
# To start outside the supervisor, export these variables manually.

[logging]
level  = "info"
format = "pretty"
